# Fastfile for Nuxbe Mobile

default_platform(:ios)

platform :ios do
  desc "Build production IPA without uploading"
  lane :build do
    setup_ci if ENV['CI']

    # Set version from tag if provided
    if ENV['APP_VERSION'] && !ENV['APP_VERSION'].empty?
      increment_version_number(
        version_number: ENV['APP_VERSION'],
        xcodeproj: "App.xcodeproj"
      )
    end

    # Set build number if provided, otherwise increment
    if ENV['BUILD_NUMBER'] && !ENV['BUILD_NUMBER'].empty?
      increment_build_number(
        build_number: ENV['BUILD_NUMBER'],
        xcodeproj: "App.xcodeproj"
      )
    end

    app_identifier = ENV['APP_IDENTIFIER'] || "com.teamnifty.nuxbe"
    prod_profile = ENV['PROVISIONING_PROFILE_SPECIFIER']

    export_opts = {
      method: "app-store",
      signingStyle: "manual"
    }

    if prod_profile && !prod_profile.empty?
      export_opts[:provisioningProfiles] = {
        app_identifier => prod_profile
      }
    end

    xcargs = []
    xcargs << "DEVELOPMENT_TEAM=YS428GD6FU"
    if prod_profile && !prod_profile.empty?
      xcargs << "PROVISIONING_PROFILE_SPECIFIER='#{prod_profile}'"
    end

    gym(
      scheme: "App",
      workspace: "App.xcworkspace",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "nuxbe-mobile.ipa",
      export_options: export_opts,
      xcargs: xcargs.join(' ')
    )
  end

  desc "Upload IPA to TestFlight"
  lane :upload do
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_filepath: File.expand_path(ENV['ASC_KEY_PATH']),
    )

    ipa_path = ENV['IPA_PATH'] || Dir['./build/**/*.ipa'].map { |f| File.expand_path(f) }.first
    UI.user_error!("No IPA file found") unless ipa_path

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Submit existing IPA to the App Store (optionally for review)"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_filepath: File.expand_path(ENV['ASC_KEY_PATH']),
    )

    # SKIP_BINARY submits the already uploaded build of this version
    # (e.g. when retrying after a failed review submission)
    skip_binary = ENV['SKIP_BINARY'] == 'true'

    ipa_path = nil
    unless skip_binary
      ipa_path = ENV['IPA_PATH'] || Dir['./build/**/*.ipa'].map { |f| File.expand_path(f) }.first
      UI.user_error!("No IPA file found") unless ipa_path
    end

    app_version = (ENV['APP_VERSION'] || '').delete_prefix('v').sub(/-.*/, '')

    # Upload metadata and release notes when the repo contains them
    has_metadata = File.directory?(File.expand_path("metadata", __dir__))

    deliver(
      api_key: api_key,
      app_identifier: ENV['APP_IDENTIFIER'] || "com.teamnifty.nuxbe",
      ipa: ipa_path,
      skip_binary_upload: skip_binary,
      app_version: app_version.empty? ? nil : app_version,
      submit_for_review: ENV['SUBMIT_FOR_REVIEW'] == 'true',
      automatic_release: false,
      skip_screenshots: true,
      skip_metadata: !has_metadata,
      run_precheck_before_submit: true,
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Download App Store metadata into the repo"
  lane :download_metadata do
    require 'json'

    # download_metadata is a deliver CLI subcommand, not an action option
    key_file = File.expand_path("../asc_api_key.json")
    File.write(key_file, {
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key: File.read(File.expand_path(ENV['ASC_KEY_PATH'])),
    }.to_json)

    begin
      sh(
        "cd .. && bundle exec fastlane deliver download_metadata " \
        "--api_key_path #{key_file.shellescape} " \
        "--app_identifier #{(ENV['APP_IDENTIFIER'] || 'com.teamnifty.nuxbe').shellescape} " \
        "--metadata_path ./fastlane/metadata " \
        "--force"
      )
    ensure
      File.delete(key_file) if File.exist?(key_file)
    end
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_filepath: File.expand_path(ENV['ASC_KEY_PATH']),
    )

    deliver(
      api_key: api_key,
      app_identifier: ENV['APP_IDENTIFIER'] || "com.teamnifty.nuxbe",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      screenshots_path: "./fastlane/screenshots",
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Build development IPA"
  lane :build_development do
    setup_ci if ENV['CI']

    app_identifier = ENV['APP_IDENTIFIER'] || "com.teamnifty.nuxbe"
    dev_profile = ENV['DEV_PROVISIONING_PROFILE_SPECIFIER']

    export_opts = {
      method: "development",
      signingStyle: "manual"
    }

    if dev_profile && !dev_profile.empty?
      export_opts[:provisioningProfiles] = {
        app_identifier => dev_profile
      }
    end

    xcargs = []
    xcargs << "DEVELOPMENT_TEAM=YS428GD6FU"
    xcargs << "CODE_SIGN_STYLE=Manual"
    if dev_profile && !dev_profile.empty?
      xcargs << "PROVISIONING_PROFILE_SPECIFIER='#{dev_profile}'"
    end

    gym(
      scheme: "App",
      workspace: "App.xcworkspace",
      configuration: "Debug",
      export_method: "development",
      clean: true,
      output_directory: "./build",
      output_name: "nuxbe-mobile-dev.ipa",
      export_options: export_opts,
      xcargs: xcargs.join(' ')
    )
  end

  desc "Download provisioning profiles"
  lane :sync_profiles do
    match(type: "appstore", readonly: true)
    match(type: "development", readonly: true)
  end

  desc "Revoke distribution certificates created today (orphaned bootstrap attempts)"
  lane :revoke_orphaned_certs do
    require 'time'

    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_filepath: File.expand_path(ENV['ASC_KEY_PATH']),
    )

    token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    Spaceship::ConnectAPI.token = token

    # A distribution certificate is valid for one year. Anything expiring more
    # than 363 days from now was created today - i.e. by a failed bootstrap.
    threshold = Time.now + (363 * 24 * 60 * 60)

    Spaceship::ConnectAPI::Certificate.all
      .select { |cert| cert.certificate_type == "DISTRIBUTION" }
      .select { |cert| Time.parse(cert.expiration_date) > threshold }
      .each do |cert|
        UI.important("Revoking orphaned distribution certificate #{cert.id} (expires #{cert.expiration_date})")
        Spaceship::ConnectAPI.delete_certificate(certificate_id: cert.id)
      end
  end

  desc "Create or renew certificates and profiles in the match repo (CI bootstrap)"
  lane :bootstrap_signing do
    setup_ci if ENV['CI']

    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_filepath: File.expand_path(ENV['ASC_KEY_PATH']),
    )

    match(type: "appstore", readonly: false, api_key: api_key)
    match(type: "development", readonly: false, api_key: api_key)
  end

  desc "Build production IPA signed via match"
  lane :build_with_match do
    setup_ci if ENV['CI']

    if ENV['APP_VERSION'] && !ENV['APP_VERSION'].empty?
      increment_version_number(
        version_number: ENV['APP_VERSION'],
        xcodeproj: "App.xcodeproj"
      )
    end

    if ENV['BUILD_NUMBER'] && !ENV['BUILD_NUMBER'].empty?
      increment_build_number(
        build_number: ENV['BUILD_NUMBER'],
        xcodeproj: "App.xcodeproj"
      )
    end

    api_key = app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_filepath: File.expand_path(ENV['ASC_KEY_PATH']),
    )

    match(type: "appstore", readonly: true, api_key: api_key)

    app_identifier = ENV['APP_IDENTIFIER'] || "com.teamnifty.nuxbe"
    profile_mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]

    gym(
      scheme: "App",
      workspace: "App.xcworkspace",
      export_method: "app-store",
      clean: true,
      output_directory: "./build",
      output_name: "nuxbe-mobile.ipa",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: profile_mapping,
      },
      xcargs: [
        "DEVELOPMENT_TEAM=YS428GD6FU",
        "CODE_SIGN_STYLE=Manual",
        "PROVISIONING_PROFILE_SPECIFIER='#{profile_mapping[app_identifier]}'",
      ].join(' ')
    )
  end

  desc "Register new device"
  lane :add_device do |options|
    register_devices(devices: { options[:name] => options[:udid] })
    match(type: "development", force_for_new_devices: true)
  end
end

platform :android do
  desc "Upload AAB to Google Play (track and release status via PLAY_TRACK / RELEASE_STATUS)"
  lane :upload do
    aab_path = ENV['AAB_PATH']
    UI.user_error!("No AAB file found - set AAB_PATH") unless aab_path

    # Upload changelogs when the repo contains Play metadata
    has_metadata = File.directory?(File.expand_path("metadata/android", __dir__))

    upload_to_play_store(
      aab: aab_path,
      track: ENV['PLAY_TRACK'] || "internal",
      release_status: ENV['RELEASE_STATUS'] || "draft",
      json_key: ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON_PATH'],
      package_name: "com.teamnifty.nuxbe",
      metadata_path: has_metadata ? "./fastlane/metadata/android" : nil,
      skip_upload_metadata: true,
      skip_upload_changelogs: !has_metadata,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Promote the latest internal build to production without re-uploading"
  lane :promote do
    upload_to_play_store(
      track: "internal",
      track_promote_to: "production",
      track_promote_release_status: ENV['RELEASE_STATUS'] || "completed",
      json_key: ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON_PATH'],
      package_name: "com.teamnifty.nuxbe",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Upload screenshots to Google Play"
  lane :upload_screenshots do
    upload_to_play_store(
      package_name: "com.teamnifty.nuxbe",
      json_key: ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON_PATH'],
      metadata_path: ENV['METADATA_PATH'] || "./fastlane/metadata/android",
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: false,
    )
  end

  desc "Download Play Store metadata into the repo"
  lane :download_metadata do
    sh("cd .. && bundle exec fastlane supply init --json_key #{ENV['PLAY_STORE_SERVICE_ACCOUNT_JSON_PATH']} --package_name com.teamnifty.nuxbe --metadata_path ./fastlane/metadata/android")
  end
end
